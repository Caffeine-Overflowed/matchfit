# Application
APP__ENV=dev
APP__LOG_LEVEL=DEBUG

# Database
DB__USERNAME=
DB__PASSWORD=
DB__HOST=localhost
DB__PORT=5432
DB__NAME=app
DB__POOL_MODE=transaction
DB__ECHO=false

# Auth
AUTH__JWT_SECRET=
AUTH__ACCESS_TTL_SEC=3600
AUTH__REFRESH_TTL_SEC=604800
AUTH__ISSUER=matchfit
AUTH__REFRESH_TOKEN_BYTES_LEN=32
AUTH__PASSWORD_MIN_LENGTH=8

# Redis
REDIS__HOST=localhost
REDIS__PORT=6379

# Google OAuth
GOOGLE__CLIENT_ID=
GOOGLE__CLIENT_SECRET=
GOOGLE__REDIRECT_URI=http://localhost:3000/auth/oauth/google

# MinIO (S3-compatible storage)
MINIO__ENDPOINT=localhost:9000
MINIO__ACCESS_KEY=
MINIO__SECRET_KEY=
MINIO__BUCKET_NAME=matchfit
MINIO__SECURE=false
MINIO__PUBLIC_URL=http://localhost:9000/matchfit
